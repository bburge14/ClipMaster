# ── OAuth Client IDs (baked into installer via GitHub Secrets) ──
# These enable "Connect YouTube" and "Connect Twitch" in Settings.
# For CI builds: add as GitHub repo secrets (Settings > Secrets > Actions).
# For local dev: copy this file to .env and fill in your values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── User API Keys (can also be added in the app's Settings UI) ──
OPENAI_API_KEY=
YOUTUBE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=
